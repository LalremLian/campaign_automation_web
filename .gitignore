# ─── Dependencies ────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build outputs ───────────────────────────────────────────
dist/
build/
out/
tmp/
.expo/
.expo-shared/

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
lib/*/dist/
lib/*/tsconfig.tsbuildinfo
client/tsconfig.tsbuildinfo
server/tsconfig.tsbuildinfo

# ─── Vite cache ──────────────────────────────────────────────
client/node_modules/.vite/
client/node_modules/.vite-temp/

# ─── Environment variables ───────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example (it's documentation — safe to commit)
!.env.example

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*

# ─── OS / System ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ─────────────────────────────────────────────────────
.idea/
*.sublime-workspace
*.sublime-project
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─── Replit (not needed locally) ─────────────────────────────
.replit-artifact/
.local/
.cache/
replit.nix
.replit

# ─── Reference / scratch assets ──────────────────────────────
attached_assets/

# ─── Coverage & testing ──────────────────────────────────────
coverage/
.nyc_output/

# ─── pnpm lock (optional: keep if you want reproducible installs) ──
# pnpm-lock.yaml
